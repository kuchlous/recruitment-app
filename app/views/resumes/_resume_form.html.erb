<div class="form-container">
  <div class="form-header">
    <h2><%= display_var == 1 ? "Edit Resume" : "New Resume" %></h2>
  </div>

  <%= form_for(@resume, :url => url_for(:host => APP_CONFIG['host_name'], :controller => "resumes", :action => (display_var == 1 ? "update" : "create")), :html => {:method => (display_var == 1 ? "put" : "post"), :multipart => true, class: "modern-form"}) do |f| %>
    
    <% if @resume.errors.any? %>
      <div class="error-messages">
        <h3><%= pluralize(@resume.errors.count, "error") %> prohibited this resume from being saved:</h3>
        <ul>
        <% @resume.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-section">
      <div class="form-group">
        <label for="resume_upload_resume">
          <% if display_var == 1 %>Update <% end %>Resume File
        </label>
        <div class="file-upload-container">
          <div class="file-input-wrapper">
            <%= f.file_field "upload_resume", class: "form-control file-input", id: "resume_upload_resume" %>
            <label for="resume_upload_resume" class="file-input-label">
              <i class="upload-icon">📄</i>
              <span>Choose File</span>
            </label>
          </div>
          <button type="button" onclick="parseResume(event)" class="btn btn-secondary parse-btn">Autofill/Parse Resume</button>
        </div>
      </div>
    </div>

    <div class="form-section">
      <div class="form-row">
        <div class="form-group">
          <label for="resume_name">Name *</label>
          <%= f.text_field :name, class: "form-control", placeholder: "Enter name" %>
        </div>
        <div class="form-group">
          <label for="resume_email">Email *</label>
          <%= f.text_field :email, class: "form-control", placeholder: "Enter email" %>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="resume_phone">Phone Number</label>
          <%= f.text_field :phone, class: "form-control", placeholder: "Enter phone" %>
        </div>
        <div class="form-group">
          <label for="resume_skype_id">Skype ID</label>
          <%= f.text_field :skype_id, class: "form-control", placeholder: "Enter Skype ID" %>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="resume_git_id">Git ID</label>
          <%= f.text_field :git_id, class: "form-control", placeholder: "Enter Git ID" %>
        </div>
        <div class="form-group">
          <label for="resume_linkedin_id">LinkedIn ID</label>
          <%= f.text_field :linkedin_id, class: "form-control", placeholder: "Enter LinkedIn ID" %>
        </div>
      </div>
      
      <div class="form-group">
        <label for="resume_skills">Skills</label>
        <%= f.text_field :skills, class: "form-control", placeholder: "Enter skills" %>
      </div>
    </div>

    <div class="form-section">
      <div class="form-row">
        <div class="form-group">
          <label for="resume_current_company">Current Company</label>
          <%= f.text_field :current_company, class: "form-control", placeholder: "Enter current company" %>
        </div>
        <div class="form-group">
          <label for="resume_location">Location</label>
          <%= f.text_field :location, class: "form-control location-autocomplete", placeholder: "Enter location", data: { autocomplete_url: url_for(:host => APP_CONFIG['host_name'], :controller => "resumes", :action => "location_autocomplete") } %>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="resume_preferred_location">Preferred Location</label>
          <%= f.text_field :preferred_location, class: "form-control location-autocomplete", placeholder: "Enter preferred location", data: { autocomplete_url: url_for(:host => APP_CONFIG['host_name'], :controller => "resumes", :action => "location_autocomplete") } %>
        </div>
        <div class="form-group">
          <label for="resume_ta_owner_id">TA Owner</label>
          <%= collection_select(:resume, :ta_owner_id, @ta_employees, :id, :name, { :prompt => "Please Select" }, class: "form-control") %>
        </div>
      </div>
      
      <div class="form-group">
        <label>Experience</label>
        <div class="experience-inputs">
          <% year, month = get_year_month_of_experience(@resume) %>
          <%= select_tag "experience_years", options_for_select(get_experience_years, year.to_i), class: "form-control experience-select" %>
          <span class="experience-label">Years</span>
          <%= select_tag "experience_months", options_for_select(get_experience_months, month.to_i), class: "form-control experience-select" %>
          <span class="experience-label">Months</span>
        </div>
      </div>
      
      <% if is_HR_ADMIN? %>
        <div class="form-row">
          <div class="form-group">
            <label for="resume_ctc">Current CTC (Lakhs)</label>
            <%= f.text_field :ctc, class: "form-control", placeholder: "Enter current CTC" %>
          </div>
          <div class="form-group">
            <label for="resume_expected_ctc">Expected CTC (Lakhs)</label>
            <%= f.text_field :expected_ctc, class: "form-control", placeholder: "Enter expected CTC" %>
          </div>
        </div>
      <% end %>
      
      <div class="form-group">
        <label for="resume_notice">Notice Period (Days)</label>
        <%= f.text_field :notice, class: "form-control", placeholder: "Enter notice period in days" %>
      </div>
    </div>

    <div class="form-section">
      <div class="form-group">
        <label for="resume_qualification">Qualification</label>
        <%= f.text_area :qualification, class: "form-control", rows: 3, placeholder: "Enter qualification details" %>
      </div>
      
      <div class="form-group">
        <label for="resume_summary">Summary</label>
        <%= f.text_area :summary, class: "form-control", rows: 4, placeholder: "Enter resume summary" %>
      </div>
    </div>

    <div class="form-section">
      <div class="form-group">
        <label for="requirement_names">Forward to Requirements</label>
        <%= text_field_tag :requirement_names, 
                          nil, 
                          class: "form-control requirements-autocomplete", 
                          placeholder: "Type requirement names to search...",
                          data: { autocomplete_url: url_for(:host => APP_CONFIG['host_name'], :controller => "requirements", :action => "autocomplete_requirements") } %>
        <small class="form-text text-muted">Type to search for requirements. Multiple requirements can be separated by commas.</small>
      </div>
      
      <% if display_var == 1 %>
        <div class="current-selection">
          <strong>Current selection:</strong><br>
          <% @resume.req_matches.each do |match| %>
            &nbsp; &middot; <%= requirement_link(match.requirement) %>(<%= match.requirement.group.name %>)<br>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="form-section">
      <div class="form-group">
        <label>Referral Type</label>
        <div class="radio-group">
          <%= f.radio_button :referral_type, "EMPLOYEE", onclick: "showReferrals([#{all_record_ids("Employee").join(", ")}], ['#{all_record_names("Employee").join("', '")}'], 0);", class: "form-check-input" %>
          <%= f.label(:referral_type_employee, "Employee", class: "form-check-label") %>
          
          <%= f.radio_button :referral_type, "PORTAL", onclick: "showReferrals([#{all_record_ids("Portal").join(", ")}], ['#{all_record_names("Portal").join("', '")}'], 1);", class: "form-check-input" %>
          <%= f.label(:referral_type_portal, "Portal", class: "form-check-label") %>
          
          <%= f.radio_button :referral_type, "AGENCY", onclick: "showReferrals([#{all_record_ids("Agency").join(", ")}], ['#{all_record_names("Agency").join("', '")}'], 2);", class: "form-check-input" %>
          <%= f.label(:referral_type_agency, "Agency", class: "form-check-label") %>
          
          <%= f.radio_button :referral_type, "DIRECT", onclick: "hideReferrals();", class: "form-check-input" %>
          <%= f.label(:referral_type_direct, "Direct", class: "form-check-label") %>
        </div>
      </div>
      
      <div class="current-referral" id="current_referral">
        <% if display_var == 1 %>
          <strong>Current Referral:</strong>
          <% if @resume.referral_type == "DIRECT" %>
            (Direct)
          <% else %>
            <% if @resume.referral_id != 0 %>
              <%= get_referral_name(@resume.referral_type, @resume.referral_id).name %> (<%= @resume.referral_type.titleize %>)
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if display_var == 1 %>
      <div class="form-section">
        <div class="form-group">
          <label for="resumes_comments">Add Resume Comments</label>
          <%= text_area "resumes", "comments", value: "", class: "form-control", rows: 3, placeholder: "Enter comments" %>
        </div>
      </div>
    <% end %>

    <div class="form-actions">
      <%= f.submit button_tag, class: "btn btn-primary" %>
      <%= link_to "Cancel", url_for(:host => APP_CONFIG['host_name'], :controller => "resumes"), class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<br /> <br />
<% url = "https://" + APP_CONFIG['host_name'] + "/extract_from_resume" %>
<script>
  function parseResume (e) {
    e.preventDefault();
    e.stopPropagation();
    var data;
    data = new FormData();
    var selectedFile = $('#resume_upload_resume')[0].files[0];
    if (!selectedFile) {
       alert("Please select resume file");
       return;
    }
    document.getElementById("loader").style.display="flex";

    data.append('resume', selectedFile );
    // ref. https://stackoverflow.com/questions/6974684/how-to-send-formdata-objects-with-ajax-requests-in-jquery
    $.ajax({
      url: '<%= url %>', 
      type: 'POST',
      data: data,
      processData: false,
      contentType: false, //'multipart/form-data', 
      // mimeType: 'multipart/form-data', 
      success: function(data) {
        if(data.ok){
          var data = data.body;
          $('#resume_name').val(data.name);
          $('#resume_email').val(data.email[0]);
          $('#resume_phone').val(data.phone[0]);
          $('#resume_skype_id').val(data.hyperlinks.skype_id[0]);
          $('#resume_git_id').val(data.hyperlinks.github[0]);
          $('#resume_linkedin_id').val(data.hyperlinks.linkedin[0]);
          $('#resume_skills').val(Object.keys(data.skills));
        } else {
          alert('HTTP Status: ' + data.status + '. Sorry, we are currently facing issues with Resume Extractor service!')
        }
        document.getElementById("loader").style.display="none";
      },
      failure: function(error) {
        document.getElementById("loader").style.display="none";
        alert(error);
      }
    });   
  }
 </script> 
