<div class="form-container">
  <div class="form-header">
    <h2>Advanced Search</h2>
  </div>

  <%= form_tag(url_for(:controller => "resumes", :action => "advanced_search_results"), :method => "get", class: "modern-form") do %>
    
    <div class="form-section">
      <div class="form-group">
        <label for="search">Search Pattern</label>
        <%= text_field_tag :search, nil, class: "form-control", id: "search_input", placeholder: "Enter search keywords" %>
        <%= hidden_field_tag :requirement_id, nil, id: "requirement_id_input" %>
        <div class="search-type mt-2 d-flex flex-wrap">
          <%= radio_button_tag :search_type, "keyword", true, class: "form-check-input me-1",
              onclick: "updateSearchInput('keyword', 'Enter search keywords');" %>
          <%= label_tag :search_type_keyword, "Keyword Search", class: "form-check-label me-3" %>
          
          <%= radio_button_tag :search_type, "phrase", false, class: "form-check-input me-1",
              onclick: "updateSearchInput('phrase', 'Enter exact phrase to match');" %>
          <%= label_tag :search_type_phrase, "Phrase Search", class: "form-check-label me-3" %>
          
          <%= radio_button_tag :search_type, "ai", false, class: "form-check-input me-1",
              onclick: "updateSearchInput('ai', 'Describe your requirement in a few words for AI search');" %>
          <%= label_tag :search_type_ai, "AI Search", class: "form-check-label me-3" %>
          
          <%= radio_button_tag :search_type, "requirement", false, class: "form-check-input me-1",
              onclick: "updateSearchInput('requirement', 'Type requirement name to search...');" %>
          <%= label_tag :search_type_requirement, "Requirement Match", class: "form-check-label me-3" %>
          
          <%= radio_button_tag :search_type, "skills", false, class: "form-check-input me-1",
              onclick: "updateSearchInput('skills', 'Enter skills to search for...');" %>
          <%= label_tag :search_type_skills, "Skills Only", class: "form-check-label" %>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="ctc_min">Min Current CTC (Lakhs)</label>
          <%= text_field_tag :ctc_min, nil, class: "form-control", placeholder: "Min CTC" %>
        </div>
        <div class="form-group">
          <label for="ctc_max">Max Current CTC (Lakhs)</label>
          <%= text_field_tag :ctc_max, nil, class: "form-control", placeholder: "Max CTC" %>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="expected_ctc_min">Min Expected CTC (Lakhs)</label>
          <%= text_field_tag :expected_ctc_min, nil, class: "form-control", placeholder: "Min Expected CTC" %>
        </div>
        <div class="form-group">
          <label for="expected_ctc_max">Max Expected CTC (Lakhs)</label>
          <%= text_field_tag :expected_ctc_max, nil, class: "form-control", placeholder: "Max Expected CTC" %>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label>Min Experience</label>
          <div class="experience-inputs">
            <%= select_tag "experience_years_min", options_for_select(get_experience_years), class: "form-control experience-select" %>
            <span class="experience-label">Years</span>
            <%= select_tag "experience_months_min", options_for_select(get_experience_months), class: "form-control experience-select" %>
            <span class="experience-label">Months</span>
          </div>
        </div>
        <div class="form-group">
          <label>Max Experience</label>
          <div class="experience-inputs">
            <%= select_tag "experience_years_max", options_for_select(get_experience_years), class: "form-control experience-select" %>
            <span class="experience-label">Years</span>
            <%= select_tag "experience_months_max", options_for_select(get_experience_months), class: "form-control experience-select" %>
            <span class="experience-label">Months</span>
          </div>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="status">Status</label>
          <%= select_tag "status", options_for_select(Resume.get_resume_statuses), class: "form-control" %>
        </div>
        <div class="form-group">
          <label for="requirement">Requirement</label>
          <%= select_tag "requirement", options_for_select(Requirement.get_all_requirement_array_for_select), class: "form-control" %>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="preferred_location">Preferred Location</label>
          <%= text_field_tag :preferred_location, nil, class: "form-control", placeholder: "e.g., Bangalore, Mumbai" %>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="uploaded_at_start">Uploaded From</label>
          <%= text_field_tag :uploaded_at_start, nil, class: "form-control datepicker", placeholder: "Select start date" %>
        </div>
        <div class="form-group">
          <label for="uploaded_at_end">Uploaded To</label>
          <%= text_field_tag :uploaded_at_end, nil, class: "form-control datepicker", placeholder: "Select end date" %>
        </div>
      </div>
      
      <div class="form-group">
        <label for="exclude_keywords">Keywords to Exclude</label>
        <%= text_field_tag :exclude_keywords, nil, class: "form-control", placeholder: "Enter keywords separated by commas (e.g., java, python, react)" %>
      </div>
    </div>

    <div class="form-actions">
      <%= submit_tag "Search", class: "btn btn-primary" %>
      <%= link_to "Cancel", url_for(:controller => "resumes"), class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<script>
let currentSearchType = 'keyword';

function updateSearchInput(searchType, placeholder) {
  const searchInput = document.getElementById('search_input');
  const requirementIdInput = document.getElementById('requirement_id_input');
  
  currentSearchType = searchType;
  searchInput.placeholder = placeholder;
  
  // Clear the input and requirement ID when switching types
  searchInput.value = '';
  requirementIdInput.value = '';
  
  // Destroy existing autocomplete if it exists
  if (searchInput.hasAttribute('data-autocomplete-initialized')) {
    $(searchInput).autocomplete('destroy');
    searchInput.removeAttribute('data-autocomplete-initialized');
  }
  
  // Initialize autocomplete for requirement search
  if (searchType === 'requirement') {
    initializeRequirementAutocomplete();
  }
}

function initializeRequirementAutocomplete() {
  const searchInput = document.getElementById('search_input');
  
  // Check if jQuery UI autocomplete is available
  if (typeof $.fn.autocomplete === 'undefined') {
    console.error('jQuery UI autocomplete plugin is not loaded');
    return;
  }
  
  $(searchInput).autocomplete({
    source: function(request, response) {
      $.ajax({
        url: prepend_with_image_path + "/requirements/autocomplete_requirements",
        dataType: "json",
        data: {
          query: request.term
        },
        success: function(data) {
          response(data.map(function(item) {
            return {
              label: item.name,
              value: item.name,
              id: item.id
            };
          }));
        }
      });
    },
    minLength: 2,
    select: function(event, ui) {
      // Set the requirement ID directly from the autocomplete response
      if (ui.item.id) {
        $("#requirement_id_input").val(ui.item.id);
      }
    }
  });
  
  searchInput.setAttribute('data-autocomplete-initialized', 'true');
}

// Also handle Turbolinks page loads
// $(document).on('turbolinks:load', function() {
  // Ensure jQuery UI is loadedkkkk
  // if (typeof $.fn.autocomplete !== 'undefined') {
//    console.log('jQuery UI autocomplete is available');
//  } else {
//    console.warn('jQuery UI autocomplete is not available');
//  }
//});
</script>
