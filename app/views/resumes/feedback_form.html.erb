<div class="form-container">
  <div class="form-header">
    <h2>Feedback for <%= @resume.name %></h2>
  </div>
  
  <table class="modern-table">
    <thead>
      <tr class="header_row">
        <td>Name</td>
        <td>Date/Time</td>
        <td>Requirement</td>
        <td>Type</td>
        <td>Focus</td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><%= resume_link(@resume) %></td>
        <td><%= @interview.interview_date.strftime("%B %d, %Y") %> at <%= @interview.interview_time.strftime("%I:%M %p") %></td>
        <td><%= requirement_link(@requirement) %></td>
        <td><%= @interview.itype.present? ? @interview.itype.titleize : "Telephonic" %></td>
        <td><%= @interview.focus.present? ? @interview.focus : "-" %></td>
      </tr>
    </tbody>
  </table>

  <%= form_with url: { controller: 'resumes', action: 'feedback' }, method: :post, local: true, id: "feedback_form", class: "modern-form" do |form| %>
    <div class="form-group">
      <label for="feedback_rating">Rating *</label>
      <select name="feedback[rating]" id="feedback_rating" class="form-control" required style="max-width: 300px;">
        <option value="">Select</option>
        <option value="Poor">Poor</option>
        <option value="Below Average">Below Average</option>
        <option value="Average">Average</option>
        <option value="Good">Good</option>
        <option value="Very Good">Very Good</option>
      </select>
    </div>

    <div class="form-group">
      <label for="resume_comment">Feedback Comments</label>
      <textarea name="resume[comment]" id="resume_comment" class="form-control" rows="6" placeholder="Add Feedback"></textarea>
    </div>

    <!-- Hidden fields -->
    <%= form.hidden_field :resume_id, value: @resume.id, name: "feedback[resume_id]" %>
    <% if @interview.present? %>
      <%= form.hidden_field :interview_id, value: @interview.id, name: "feedback[interview_id]" %>
    <% end %>
    <% if @requirement.present? %>
      <%= form.hidden_field :requirement_name, value: @requirement.name, name: "requirement_name" %>
    <% end %>

    <div class="form-actions">
      <%= form.submit "Submit Feedback", class: "btn btn-primary" %>
      <%= link_to "Cancel", { controller: 'resumes', action: 'interview_requests' }, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
