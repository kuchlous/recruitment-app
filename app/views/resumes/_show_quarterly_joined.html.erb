<% if local_assigns[:resumes].present? %>
  <table id="joined_resumes_table" class="sortable modern-table">
    <thead>
      <tr>
        <th> Name </th>
        <th class="sorttable_alpha"> Requirement </th>
        <th> Joined date </th>
        <th> Experience </th>
      </tr>
    </thead>
    <tbody>
      <% local_assigns[:resumes].each do |r| %>
        <tr>
          <td class="table-cell-primary"> <%= resume_link(r) %> </td>
          <td class="table-cell-secondary"> <%= get_resume_requirement(r, local_assigns[:status]) %> </td>
          <td class="table-cell-secondary"> <%= print_date(r.joining_date) %> </td>
          <td class="table-cell-secondary"> <%= r.experience %> </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="table-empty">
    <div class="empty-icon">📋</div>
    <p>No resumes found for the selected date range.</p>
  </div>
<% end %>
