<% if params[:action] == "show_quarterly_not_accepted"
     month_year_str  = Date::ABBR_MONTHNAMES[@smonth] + ".." + Date::ABBR_MONTHNAMES[@emonth] + " " + @year.to_s
   end %>

<div class="table-header">
  <% if params[:action] == "show_quarterly_not_accepted" %>
    <h2><%= month_year_str %> (<%= @not_accepted_comments.size %>)</h2>
  <% elsif params[:action] == "show_all_not_accepted" %>
    <h2>ALL <%= @status.titleize %> Resumes (<%= @not_accepted_comments.size %>)</h2>
  <% else %>
    <h2><%= @status.titleize %> resumes for current quarter (<%= @not_accepted_comments.size %>)</h2>
  <% end %>
  <p>Detailed refusal information and statistics</p>
</div>

<table id="not_accepted_resumes_table" class="sortable modern-table">
  <thead>
    <tr>
      <th> Name </th>
      <th> Requirement </th>
      <th> Refusal date </th>
      <th> Experience </th>
    </tr>
  </thead>
  <tbody>
    <% @not_accepted_comments.each do |c| %>
      <tr>
        <td class="table-cell-primary"> <%= resume_link(c[:not_accepted].resume) %> </td>
        <td class="table-cell-secondary"> <%= c[:offered] ? get_requirement_from_comment(c[:offered], "OFFERED") ? requirement_link(get_requirement_from_comment(c[:offered], "OFFERED")) : "Not Available" : "Not Available" %> </td>
        <td class="table-cell-secondary"> <%= print_date_and_time(c[:not_accepted].created_at) %> </td>
        <td class="table-cell-secondary"> <%= get_current_experience_string(c[:not_accepted].resume) %> </td>
      </tr>
    <% end %>
  </tbody>
</table>
