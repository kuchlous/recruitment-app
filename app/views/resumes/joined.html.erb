<% @status = "JOINING" %>
<div id="resumes_joined" class="table-container">
  <div class="table-header">
    <h2>Monthly Summary</h2>
  </div>
  
  <table id="summary_table" class="modern-table">
    <thead>
      <tr>
        <th> </th>
        <% @months_table.each do |m| %>
          <th> <%= print_month_and_year(Date::civil(m[:year], m[:month], 1)) %> </th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <tr>
        <th> Joined </th>
        <% @months_table.each do |m| %>
          <td class="table-cell-secondary"> <%= m[:joined] %> </td>
        <% end %>
      </tr>
      <tr>
        <th> Joining </th>
        <% @months_table.each do |m| %>
          <td class="table-cell-secondary"> <%= m[:joining] %> </td>
        <% end %>
      </tr>
      <tr>
        <th> Not Joined </th>
        <% @months_table.each do |m| %>
          <td class="table-cell-secondary"> <%= m[:not_joined] %> </td>
        <% end %>
      </tr> 
    </tbody>
  </table>

  <div class="table-header">
    <h2><%= @status.titleize + "(" + @matches.size.to_s + ")" %></h2>
  </div>
  
  <div class="table-footer">
    <div class="table-pagination">
      <%= link_to "Expand", '#', :onclick => "show_column_for_date_when_resume_moved_to_joining(); return false;", :class => "action-link" %>
    </div>
  </div>
  
  <% if @matches && @matches.size > 0 %>
    <table id="joining_resumes_table" class="sortable modern-table">
      <thead>
        <tr>
          <th> Name   </th>
          <th class="sorttable_alpha"> Requirement   </th>
          <th> Joining Date  </th>
          <th> Likely to join </th>
          <th class="hidden_by_default"> Accept Date  </th>
        </tr>
      </thead>
      <tbody>
      <% @matches.each do |f|
        resume = f.resume %>
        <tr>
          <td class="table-cell-primary">
            <%= resume_link(resume) %>
          </td>
          <td sorttable_customkey="<%= f.requirement.name %>" class="table-cell-secondary">
            <%= f.requirement.name %>
          </td>
          <td class="table-cell-secondary">
            <%= link_to print_date(resume.joining_date), "", :onClick=>"showEditJoiningBox(event, #{resume.id}, #{f.id})" %>
          </td>
          <td id=<%= "likely-to-join-" + resume.id.to_s %> class="table-cell-secondary">
            <%= image_tag("#{get_image_name(resume)}_Image.png", :size => "20x20", :onClick=>"showAllImagesForLikelyToJoin(event," + resume.id.to_s + ")") %>
          </td>
          <td class="hidden_by_default table-cell-secondary">
            <% joining_date = ""
               if (get_date_when_resume_moved_to_joining(resume))
                 joining_date = print_date(get_date_when_resume_moved_to_joining(resume))
               else
                 joining_date = "Not Available";
               end %>
            <%= joining_date %>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="table-empty">
      <div class="empty-icon">📋</div>
      <p>No resumes given joining date.</p>
    </div>
  <% end %>

  <div class="table-header">
    <h2> Joined (<%=@joined_resumes.size%>) </h2>
    <%= render "resumes/month_year_selector", url: url_for(host: APP_CONFIG['host_name'], controller: 'resumes', action: 'show_quarterly_joined') %>
  </div>

  <div id="joined_resumes_div">
    <% if @joined_resumes.present? %>
      <%= render "resumes/show_quarterly_joined", :resumes => @joined_resumes, :status => "JOINED" %>
    <% else %>
      <div class="table-empty">
        <div class="empty-icon">📋</div>
        <p>No joined resumes found.</p>
      </div>
    <% end %>
  </div>

  <div class="table-header">
    <h2>Not Joined (<%=@not_joined_resumes.size%>)</h2>
    <%= render "resumes/month_year_selector", url: url_for(host: APP_CONFIG['host_name'], controller: 'resumes', action: 'show_quarterly_not_joined') %>
  </div>
  
  <div id="not_joined_resumes_div">
    <% if @not_joined_resumes.present? %>
      <%= render "resumes/show_quarterly_joined", :resumes => @not_joined_resumes, :status => "NOT JOINED" %>
    <% else %>
      <div class="table-empty">
        <div class="empty-icon">📋</div>
        <p>No not joined resumes found.</p>
      </div>
    <% end %>
  </div>

  <div class="table-header">
    <h2>Offers Made (<%=@offered_comments.size%>) </h2>
    <%= render "resumes/month_year_selector", url: url_for(host: APP_CONFIG['host_name'], controller: 'resumes', action: 'show_quarterly_offered') %>
  </div>
  
  <div id="offered_resumes_div">
    <% @status = "OFFERED" %>
    <% if @offered_comments.present? %>
      <%= render "resumes/show_quarterly_offered", :status => @status %>
    <% else %>
      <div class="table-empty">
        <div class="empty-icon">📋</div>
        <p>No offered resumes found.</p>
      </div>
    <% end %>
  </div>

  <div class="table-header">
    <h2>Not Accepted (<%=@not_accepted_comments.size%>)</h2>
    <%= render "resumes/month_year_selector", url: url_for(host: APP_CONFIG['host_name'], controller: 'resumes', action: 'show_quarterly_not_accepted') %>
  </div>
  
  <div id="not_accepted_resumes_div">
    <% @status = "NOT ACCEPTED" %>
    <% if @not_accepted_comments.present? %>
      <%= render "resumes/show_quarterly_not_accepted", :status => @status %>
    <% else %>
      <div class="table-empty">
        <div class="empty-icon">📋</div>
        <p>No not accepted resumes found.</p>
      </div>
    <% end %>
  </div>
</div>
