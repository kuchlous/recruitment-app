<div id="resume_search_div" class="common_class">
  <div class="table-header">
    <h2>All <%= @status %> Resumes</h2>
    <p><%= @resumes.size %> resumes found</p>
  </div>
  
  <% if @resumes.size > 0 %>
    <table class="modern-table sortable">
      <thead>
        <tr>
          <th>Name</th>
          <th>Upload Date</th>
          <th>Overall Status</th>
          <th>Recent Activity On</th>
          <th>Phone Number</th>
          <th>Email</th>
        </tr>
      </thead>
      <tbody>
        <% @resumes.each do |resume| %>
          <tr>
            <td class="table-cell-primary" title="<%= resume.name %>">
              <%= resume_link(resume) %>
            </td>
            <td class="table-cell-secondary">
              <%= print_date(resume.created_at) %>
            </td>
            <td class="table-cell-secondary">
              <%= resume.overall_status %>
            </td>
            <td class="table-cell-secondary">
              <%= print_date(resume.change_date) %>
            </td>
            <td class="table-cell-truncated" title="<%= resume.phone %>">
              <%= resume.phone %>
            </td>
            <td class="table-cell-truncated" title="<%= resume.email %>">
              <%= resume.email %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="table-empty">
      <div class="empty-icon">📄</div>
      <p>Sorry, there are no resumes found.</p>
    </div>
  <% end %>
</div>
