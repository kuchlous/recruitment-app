<div class="container">
  <div>
    <%= select_tag :form_config_id, options_from_collection_for_select(FormConfig.all, :id, :title), prompt: 'Select Form Config' %>
  </div>
  <br />
  <div id="formPreviewContainer"></div>
  <div id="formPreviewTable"></div>
</div>
<script>
  document.addEventListener('turbolinks:load', () => {
    const formPreviewContainerFound = document.querySelector('#formPreviewContainer');
    if (!formPreviewContainerFound) return;

    const formConfigSelect = document.getElementById('form_config_id');

    function fetchAndRenderFormConfig(formConfigId) {
      if (!formConfigId) return;
      const fetchUrl = `${prepend_with_image_path}/get_form_config?id=${formConfigId}`;
      fetch(fetchUrl)
        .then(response => {
          if (!response.ok) {
            throw new Error(`HTTP Error! status: ${response.status}`);
          }
          return response.json();
        })
        .then(formConfig => {
          if (formConfig) {
            generateDynamicForm('formPreviewContainer', formConfig);
          } else {
            console.error('Invalid form configuration received:', formConfig);
          }
        })
        .catch(error => {
          console.error('Error fetching form configuration:', error);
        });
    }

    if (formConfigSelect) {
      formConfigSelect.addEventListener('change', function() {
        const selectedId = this.value;
        if (selectedId) {
          fetchAndRenderFormConfig(selectedId);
        }
      });
    }

    // Optionally, fetch initial config if a value is pre-selected
    if (formConfigSelect && formConfigSelect.value) {
      fetchAndRenderFormConfig(formConfigSelect.value);
    }
  });
</script>