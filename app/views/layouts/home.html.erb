<!DOCTYPE HTML PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xml:lang="en" xmlns="http://www.w3.org/1999/xhtml" lang="en">
 <head>
    <title> Mirafra - Recruitment Drive </title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <%= javascript_tag "prepend_with_image_path = '#{APP_CONFIG['subdomain']}'" %>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community/dist/styles/ag-grid.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community/dist/styles/ag-theme-alpine.css">
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload' %>

    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community/dist/ag-grid-community.min.js"></script>
    <%= javascript_include_tag 'application', 'data-turbo-track': 'reload' %>

    <link href="/assets/favicon.ico" rel="shortcut icon" type="image/x-icon" />
    <%= yield :head %>
  </head>
  <body>
    <div id="allcontent">
      <div id="loader">
        <%= link_to image_tag("loading-t.gif") %>
      </div>
      <table width="100%" id="top_table" border="0" cellpadding="0" cellspacing="0">
        <tbody>
          <tr id="logo_row">
            <td class="logo">
              <%= link_to image_tag("MirafraLogo.gif", :size => "120x40" ), {:controller => "home", :action => "index"}, :id => "logo_link", :title => "Recuitment Database" %>
            </td>
            <td class="logo_tagline">
              Mirafra Recruitment
            </td>
          </tr>
        </tbody>
      </table>
      <div id="content">
        <%= render("shared/empl_top_line") %>
        <br /> <br /> <br />
        <div id="emp_layout">
          <% if params[:action] == "interview_requests" %>
            <form action="" name="form" id="interview_requests_form">
          <% end %>
          <%= yield :layout %>
          <% if params[:action] == "interview_requests" %>
            </form>
          <% end %>
        </div>
      </div>
      <div id="footer">
        <table id="footer_table">
          <tbody>
            <tr>
              <td class="confidential_tag">
                Mirafra Technologies Confidential
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <% unless flash[:notice].nil? -%>
        <script>
          showBootstrapAlert('<%= j flash[:notice] %>', 'success');
        </script>
        <% flash[:notice] = nil %>
      <% end %>
      
      <% unless flash[:alert].nil? -%>
        <script>
          showBootstrapAlert('<%= j flash[:alert] %>', 'warning');
        </script>
        <% flash[:alert] = nil %>
      <% end %>
      
      <% unless flash[:error].nil? -%>
        <script>
          showBootstrapAlert('<%= j flash[:error] %>', 'danger');
        </script>
        <% flash[:error] = nil %>
      <% end %>
      
      <% unless flash[:info].nil? -%>
        <script>
          showBootstrapAlert('<%= j flash[:info] %>', 'info');
        </script>
        <% flash[:info] = nil %>
      <% end %>
    </div>
  </body>
</html>
