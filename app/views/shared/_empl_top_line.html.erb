<% if  get_current_employee %>
  <div id="employee_logged_info">
    <% current_employee = get_current_employee  
       logged_employee  = get_logged_employee %>
    <div id="logged_info">
      <div id="logging_name_info">
        Login: <b> <%=  get_words(logged_employee.name, 2) %> </b> |
        <%= link_to "Logout", :controller => "employees", :action => "logout" %>
        <% if logged_employee != current_employee %>
          | <%= link_to "My Account", :controller => "employees", :action => "change_to", :id => logged_employee.id %>
        <% end %>
      </div>
      <br /> <br />
      <% if is_HR_ADMIN? || is_BD? || is_GM? || is_REQ_MANAGER? || is_MANAGER? %>
        <div id="search_box">
          <%= form_tag :controller => "resumes", :action => "search", :method => 'post' do %>
            <table>
              <tr>
                <td class="search_box_field">         <%= text_field "search", "box" %> </td>
                <td class="search_box_submit_button"> <%= submit_tag "Search" %> </td>
              </tr>
            </table>
          <% end %>
          <%= link_to "(Advanced Search)", {:controller => "resumes", :action => "advanced_search"}, :class => "float_right_with_no_padding" %>
        </div>
      <% end %>
    </div>
    <div id="user_action_list">
      <% if logged_employee != current_employee %>
        Account: <b> <%= current_employee.name.split(' ')[0..1].join(' ') %> </b> ||
      <% end %>
      <% if is_HR? %>
        <%= link_to "Upload Resume", :controller => "resumes", :action => "new" %>
        | <%= link_to "Interview XL", :controller => "resumes", :action => "export_interviews_per_date" %>
      <% end %>
      | <%= link_to "My Interviews", {:controller => "resumes", :action => "interview_requests" } %>
      | <%= link_to "My Resumes", :controller => "resumes", :action => "my_resumes" %>
      | <%= link_to "Interview Calendar", :controller => "resumes", :action => "interview_calendar" %>
      <% if is_ADMIN? %>
        | <%= link_to "All employees", :controller => "employees", :action => "index" %>
      <% elsif current_employee.is_manager? %>
        | <%= link_to "My employees", :controller => "employees", :action => "list_my_employees" %>
      <% end %>
      <% if is_HR_ADMIN? || is_GM? %>
        | <%= link_to "Misc.", { :controller => "home",    :action => "actions" },       :class => "primary_action", :id => "misc_home", :onmouseover => "showSecondaryActions('misc_home');", :onfocus => "showSecondaryActions('misc_home');" %>
      <% else %>
        | <%= link_to "All Requirements", { :controller => "requirements", :action => "index" } %>
        | <%= link_to "My Requirements", { :controller => "requirements", :action => "my_requirements" } %>
      <% end %>
        | <%= link_to "Messages", { :controller => "resumes", :action => "inbox" },         :class => "primary_action", :id => "messages_home", :onmouseover => "showSecondaryActions('messages_home');", :onfocus => "showSecondaryActions('messages_home');" %>
      <% if is_HR_ADMIN? %>
        | <%= link_to "Export XLS", :controller => "resumes", :action => "export_as_xls" %>
      <% end %>
      <% if is_TA_HEAD? %>
        | <%= link_to "Reports", { :controller => "report_generator", :action => "reports" }, :class => "primary_action", :id => "reports_home", :onmouseover => "showSecondaryActions('reports_home');", :onfocus => "showSecondaryActions('reports_home');" %>
      <% end %>
    </div>
    <div id="user_secondary_action_list">
      <div id="messages_home_actions">
        <%= link_to "Inbox",                    {  :controller => "resumes", :action => "inbox"  }, :class  => "secondary_action" %>
        <%= link_to "Outbox",                   {  :controller => "resumes", :action => "outbox"  }, :class  => "secondary_action" %>
        <%= link_to "Trash",                    {  :controller => "resumes", :action => "trash"  }, :class  => "secondary_action" %>
      </div>
      <% if is_HR_ADMIN? || is_GM? %>
        <div id="misc_home_actions">
          <%= link_to "All Requirements",         {  :controller => "requirements" },  :class => "secondary_action" %>
          <%= link_to "My Requirements",          {  :controller => "requirements",    :action => "my_requirements" }, :class => "secondary_action" %>
          <%= link_to "Interview Panels",         {  :controller => "home", :action => "interview_panels" }, :class => "secondary_action" %>

          <% if is_HR_ADMIN? %>
            <%= link_to "Designations",           {  :controller => "designations" },  :class => "secondary_action" %>
            <%= link_to "Groups",                 {  :controller => "groups"       },  :class => "secondary_action" %>
            <%= link_to "Portals",                {  :controller => "portals"      },  :class => "secondary_action" %>
            <%= link_to "Agencies",               {  :controller => "agencies"     },  :class => "secondary_action" %>
          <% end %>
          <% if is_ADMIN? || is_GM? %>
            <%= link_to "Summaries",             {  :controller => "home", :action => "summaries"}, :class => "secondary_action" %>
          <% end %>
          <% if is_HR_ADMIN? %>
            <%= link_to "Office Locations",      {  :controller => "officelocations", :action => "index"}, :class => "secondary_action" %>
          <% end %>
        </div>
      <% end %>
      <% if is_TA_HEAD? %>
        <div id="reports_home_actions">
          <%= link_to "Requirement Reports", { :controller => "report_generator", :action => "reports" }, :class => "secondary_action" %>
          <%= link_to "TA Owner Reports", { :controller => "report_generator", :action => "ta_owner_reports" }, :class => "secondary_action" %>
        </div>
      <% end %>
    </div>
  </div>
  <div id="bottom_fixed_div">
    <table id="bottom_fixed_table">
      <tr>
        <% if is_HR? %>
          <td> <%= link_to "New",         :controller => "resumes", :action => "new_resumes"         %> </td>
        <% end %>
        <% if is_HR_ADMIN? || is_PM? || is_BD? || is_GM? || is_BenchManager?
               hold       = "hold"
               offered    = "offered"
               joined     = "joined"
               interviews = "interviews_status"
               yto        = "yto"
               eng_select = "eng_select"
               hac        = "hac"
               shortlisted = "shortlisted"
               forwarded  = "forwarded"
               future     = "future"
           elsif is_REQ_MANAGER? 
               hold       = "manager_hold"
               offered    = "manager_offered"
               joined     = "manager_joined"
               interviews = "manager_interviews_status"
               yto        = "manager_yto"
               eng_select = "manager_eng_select"
               hac        = "manager_hac"
               shortlisted = "manager_shortlisted"
               forwarded  = "manager_index"
               future     = "future"
           end
        %>
        <% if is_PM?
          joined = "joined"
          end
        %>
        <% if is_HR?
          recent = "recent"
          end
        %>
        <% if forwarded   %> <td> <%= link_to "Forwarded",   :controller => "resumes", :action => "#{forwarded}"   %>    </td> <% end %>
        <% if shortlisted %> <td> <%= link_to "Shortlisted", :controller => "resumes", :action => "#{shortlisted}" %>    </td> <% end %>
        <% if interviews  %> <td> <%= link_to "Interviews",  :controller => "resumes", :action => "#{interviews}"  %>    </td> <% end %>
        <% if eng_select  %> <td> <%= link_to "Eng Select",  :controller => "resumes", :action => "#{eng_select}"         %>    </td> <% end %>
        <% if hac         %> <td> <%= link_to "HAC",         :controller => "resumes", :action => "#{hac}"         %>    </td> <% end %>
        <% if yto         %> <td> <%= link_to "YTO",         :controller => "resumes", :action => "#{yto}"         %>    </td> <% end %>
        <% if hold        %> <td> <%= link_to "Hold",        :controller => "resumes", :action => "#{hold}"        %>    </td> <% end %>
        <% if offered     %> <td> <%= link_to "Offered",     :controller => "resumes", :action => "#{offered}"     %>    </td> <% end %>
        <% if joined      %> <td> <%= link_to "Joining",     :controller => "resumes", :action => "#{joined}"      %>    </td> <% end %>
        <% if future      %> <td> <%= link_to "Future",      :controller => "resumes", :action => "#{future}"      %>    </td> <% end %>
        <% if recent      %> <td> <%= link_to "Recent",      :controller => "resumes", :action => "#{recent}", :all => '1'     %>    </td> <% end %>
      </tr>
    </table>
  </div>
<% end %>
