<div id="show_requirements_description_div_<%= @status %>">
  <span class="span_with_13_with_padding_0"> <%= @status.titleize %>
    (<%= (@render == "manager_index") ? @forwards.size : @matches.size %>)
  </span>
  <% render_type = (@render == "interview_table") ? @render : "shared_" + @render %>
  <%= link_to "Export", url_for(:controller => "resumes", :action => "export_as_xls_requirement_for_status", :requirement_id => @requirement.id, :status => @status), data: {turbolinks: false} %>
  <%= render "resumes/#{render_type}" %>
</div>
