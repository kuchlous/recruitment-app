<div class="dashboard-container">
  <div class="dashboard-header">
    <h2>Interview Reports (Per Requirement)</h2>
    <div class="dashboard-header-links">
      <%= link_to(
        "Requirement Reports",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "reports"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "Requirement Pipeline Reports",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "pipeline_report"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "TA Owner Reports",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "ta_owner_reports"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "Interview Reports (TA Owner)",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "interview_reports_ta_owner"
        ),
        class: "action-link"
      ) %>
      <% if @report_data && @report_data.any? %>
      <% 
          export_params = { period: @period }
          if @period == 'daily'
            export_params[:date] = @start_date
          else
            export_params[:start_date] = @start_date
          end
        %>
      <%= link_to(
        "Export to Excel",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "export_interview_reports_per_requirement",
          **export_params
        ),
        class: "action-link success",
        target: "_blank"
      ) %>
      <% end %>
    </div>
  </div>

  <%= render(
    'report_filter',
    path: url_for(
      host: APP_CONFIG['host_name'],
      controller: "report_generator",
      action: "interview_reports_per_requirement"
    )
  ) %>

  <div class="table-container">
    <% if @report_data && @report_data.any? %>
    <table class="modern-table">
      <thead>
        <tr>
          <th>Requirement Name</th>
          <th>Candidate Name</th>
          <th>Interview Date</th>
          <th>Interview Time</th>
          <th>Interview Mode</th>
          <th>Panel Name</th>
          <th>Link</th>
          <th>Rounds</th>
          <th>Status</th>
          <th>Interview Cancelled/Deleted</th>
          <th>TA Owner</th>
        </tr>
      </thead>
      <tbody>
        <% @report_data.each do |row| %>
        <tr>
          <td class="table-cell-primary">
            <% if row['requirement_id'].present? %>
              <%= link_to(
                row['requirement_name'].presence || 'N/A',
                url_for(
                  host: APP_CONFIG['host_name'],
                  controller: "requirements",
                  action: "show",
                  id: row['requirement_id']
                ),
                target: "_blank",
                class: "action-link"
              ) %>
            <% else %>
              <%= row['requirement_name'].presence || 'N/A' %>
            <% end %>
          </td>
          <td class="table-cell-primary">
            <% if row['uniqid_name'].present? %>
              <%= link_to(
                row['candidate_name'],
                url_for(
                  host: APP_CONFIG['host_name'],
                  controller: "resumes",
                  action: "show",
                  id: row['uniqid_name']
                ),
                target: "_blank",
                class: "action-link"
              ) %>
            <% else %>
              <%= row['candidate_name'] %>
            <% end %>
          </td>
          <td class="table-cell-secondary"><%= format_report_date(row['interview_date']) %></td>
          <td class="table-cell-secondary"><%= row['interview_time'].present? ? format_interview_time(row['interview_time']) : '' %></td>
          <td class="table-cell-secondary"><%= row['interview_mode'] %></td>
          <td class="table-cell-secondary"><%= row['panel_name'] %></td>
          <td class="table-cell-primary">
            <% if row['uniqid_name'].present? %>
              <%= link_to(
                "View",
                url_for(
                  host: APP_CONFIG['host_name'],
                  controller: "resumes",
                  action: "show",
                  id: row['uniqid_name']
                ),
                target: "_blank",
                class: "action-link"
              ) %>
            <% else %>
              —
            <% end %>
          </td>
          <td class="table-cell-secondary"><%= row['round_label'] %></td>
          <td class="table-cell-secondary"><%= row['status_label'] %></td>
          <td class="table-cell-secondary"><%= row['cancelled_flag'] %></td>
          <td class="table-cell-secondary"><%= row['ta_owner_name'] %></td>
        </tr>
        <% end %>
      </tbody>
    </table>
    <% else %>
    <p style="text-align: center; padding: 40px; color: #6c757d; font-size: 16px;">No data available for the selected period.</p>
    <% end %>
  </div>
</div>
