<div class="dashboard-container">
  <div class="dashboard-header">
    <h2>TA Owner Reports</h2>
    <div class="dashboard-header-links">
      <%= link_to(
        "Requirement Reports",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "reports"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "Requirement Pipeline Reports",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "pipeline_report"
        ),
        class: "action-link"
      ) %>
      <% if @report_data && @report_data.any? %>
      <% 
          export_params = { period: @period }
          if @period == 'daily'
            export_params[:date] = @start_date
          else
            export_params[:start_date] = @start_date
          end
        %>
      <%= link_to(
        "Export to Excel",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "export_ta_owner_reports",
          **export_params
        ),
        class: "action-link success",
        target: "_blank"
      ) %>
      <% end %>
    </div>
  </div>

  <%= render(
    'report_filter',
    path: url_for(
      host: APP_CONFIG['host_name'],
      controller: "report_generator",
      action: "ta_owner_reports"
    )
  ) %>

  <div class="table-container">
    <% if @report_data && @report_data.any? %>
    <table class="modern-table">
      <thead>
        <tr>
          <th>TA Owner</th>
          <th>Forward Date</th>
          <th>Candidate Name</th>
          <th>Requirement Name</th>
          <th>TA Leads</th>
          <th>Skills</th>
          <th>Company Name</th>
          <th>Total Experience</th>
          <th>Current CTC</th>
          <th>Expected CTC</th>
          <th>Notice Period</th>
          <th>Serving Notice Period (Yes/No)</th>
          <th>LWD</th>
          <th>Current Location</th>
          <th>Preferred Location</th>
        </tr>
      </thead>
      <tbody>
        <% @report_data.each do |row| %>
        <tr>
          <td class="table-cell-secondary"><%= row['ta_owner_name'] %></td>
          <td class="table-cell-secondary"><%= row['forward_date'] %></td>
          <td class="table-cell-primary">
            <% if row['uniqid_name'] %>
            <%= link_to(
                row['candidate_name'],
                url_for(
                  host: APP_CONFIG['host_name'],
                  controller: "resumes",
                  action: "show",
                  id: row['uniqid_name']
                ),
                target: "_blank",
                class: "action-link"
              ) %>
            <% else %>
            <%= row['candidate_name'] %>
            <% end %>
          </td>
          <td class="table-cell-secondary">
            <% if row['requirement_id'] %>
            <%= link_to(
                row['requirement_name'],
                url_for(
                  host: APP_CONFIG['host_name'],
                  controller: "requirements",
                  action: "show",
                  id: row['requirement_id']
                ),
                target: "_blank",
                class: "action-link"
              ) %>
            <% else %>
            <%= row['requirement_name'] %>
            <% end %>
          </td>
          <td class="table-cell-secondary"><%= row['ta_leads'] %></td>
          <td class="table-cell-secondary" title="<%= row['skills'] %>"><%= truncate(row['skills'] || '', length: 50) %></td>
          <td class="table-cell-secondary"><%= row['company_name'] %></td>
          <td class="table-cell-secondary"><%= row['total_experience'] %></td>
          <td class="table-cell-secondary"><%= row['current_ctc'] %></td>
          <td class="table-cell-secondary"><%= row['expected_ctc'] %></td>
          <td class="table-cell-secondary"><%= row['notice_period'] %></td>
          <td class="table-cell-secondary"><%= row['serving_notice'] %></td>
          <td class="table-cell-secondary"><%= row['lwd'] %></td>
          <td class="table-cell-secondary"><%= row['current_location'] %></td>
          <td class="table-cell-secondary"><%= row['preferred_location'] %></td>
        </tr>
        <% end %>
      </tbody>
    </table>
    <% else %>
    <p style="text-align: center; padding: 40px; color: #6c757d; font-size: 16px;">No data available for the selected period.</p>
    <% end %>
  </div>
</div>
