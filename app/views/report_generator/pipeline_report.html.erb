<div class="dashboard-container">
  <div class="dashboard-header">
    <h2>Requirement Pipeline Reports</h2>
    <div class="dashboard-header-links">
      <%= link_to(
        "Requirement Reports",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "reports"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "TA Owner Reports",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "ta_owner_reports"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "Interview Reports (TA Owner)",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "interview_reports_ta_owner"
        ),
        class: "action-link"
      ) %>
      <% if @report_data && @report_data.any? %>
      <% 
          export_params = { period: @period }
          if @period == 'daily'
            export_params[:date] = @start_date
          else
            export_params[:start_date] = @start_date
          end
        %>
      <%= link_to(
        "Export to Excel",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "export_pipeline_report",
          **export_params
        ),
        class: "action-link success",
        target: "_blank"
      ) %>
      <% end %>
    </div>
  </div>

  <%= render(
    'report_filter',
    path: url_for(
      host: APP_CONFIG['host_name'],
      controller: "report_generator",
      action: "pipeline_report"
    )
  ) %>

  <div class="table-container">
    <% if @report_data && @report_data.any? %>
    <table class="modern-table">
      <thead>
        <tr>
          <th>TA Owner</th>
          <th>Group Name</th>
          <th>Requirement Name</th>
          <th>Forwarded</th>
          <th>Skills</th>
          <th>Shortlisted</th>
          <th>No of Candidates Interviewed</th>
          <th>Total Rounds of Interviews</th>
          <th>Total EHD Sent</th>
          <th>Engineering Select</th>
          <th>HAC</th>
          <th>Total YTO</th>
          <th>Offered</th>
          <th>Not Accepted</th>
          <th>Joined</th>
          <th>Not Joined</th>
          <th>Rejected</th>
        </tr>
      </thead>
      <tbody>
        <% @report_data.each do |row| %>
        <tr>
          <td class="table-cell-secondary"><%= row['ta_owner_name'] %></td>
          <td class="table-cell-secondary"><%= row['group_name'] %></td>
          <td class="table-cell-primary">
            <%= link_to(
              row['requirement_name'],
              url_for(
                host: APP_CONFIG['host_name'],
                controller: "requirements",
                action: "show",
                id: row['requirement_id']
              ),
              target: "_blank",
              class: "action-link"
            ) %>
          </td>
          <td class="table-cell-secondary"><%= row['total_forwards'] %></td>
          <td class="table-cell-secondary" title="<%= h(row['skills']) %>">
            <%= truncate(row['skills'], length: 100) %>
          </td>
          <td class="table-cell-secondary"><%= row['total_shortlists'] %></td>
          <td class="table-cell-secondary"><%= row['total_interviews'] %></td>
          <td class="table-cell-secondary"><%= row['total_rounds'] %></td>
          <td class="table-cell-secondary"><%= row['total_ehd'] %></td>
          <td class="table-cell-secondary"><%= row['total_eng_select'] %></td>
          <td class="table-cell-secondary"><%= row['total_hac'] %></td>
          <td class="table-cell-secondary"><%= row['total_yto'] %></td>
          <td class="table-cell-secondary"><%= row['total_offered'] %></td>
          <td class="table-cell-secondary"><%= row['total_not_accepted'] %></td>
          <td class="table-cell-secondary"><%= row['total_joined'] %></td>
          <td class="table-cell-secondary"><%= row['total_not_joined'] %></td>
          <td class="table-cell-secondary"><%= row['total_rejects'] %></td>
        </tr>
        <% end %>
      </tbody>
    </table>
    <% else %>
    <p style="text-align: center; padding: 40px; color: #6c757d; font-size: 16px;">No data available for the selected period.</p>
    <% end %>
  </div>
</div>
