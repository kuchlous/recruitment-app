<div class="dashboard-container">
  <div class="dashboard-header">
    <h2>Requirement Pipeline Reports</h2>
    <div class="dashboard-header-links">
      <%= link_to(
        "Requirement Reports",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "reports"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "TA Owner Reports",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "ta_owner_reports"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "Interview Reports (TA Owner)",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "interview_reports_ta_owner"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "Interview Reports (Per Requirement)",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "interview_reports_per_requirement"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "Interview Reports (Per Panel)",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "interview_reports_per_panel"
        ),
        class: "action-link"
      ) %>
      <%= link_to(
        "Hiring Decision Report",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "hiring_decision_report"
        ),
        class: "action-link"
      ) %>
      <% if @report_data && @report_data.any? %>
      <% 
          export_params = { period: @period }
          if @period == 'daily'
            export_params[:date] = @start_date
          else
            export_params[:start_date] = @start_date
          end
        %>
      <%= link_to(
        "Export to Excel",
        url_for(
          host: APP_CONFIG['host_name'],
          controller: "report_generator",
          action: "export_pipeline_report",
          **export_params
        ),
        class: "action-link success",
        target: "_blank"
      ) %>
      <% end %>
    </div>
  </div>

  <%= render(
    'report_filter',
    path: url_for(
      host: APP_CONFIG['host_name'],
      controller: "report_generator",
      action: "pipeline_report"
    )
  ) %>

  <div class="table-container">
    <% if @report_data && @report_data.any? %>
    <div class="table-actions table-actions--toolbar-end">
      <button type="button" id="pipeline-reports-clear-filters" class="form-submit-btn">Clear all filters</button>
      <button type="button" id="pipeline-reports-export-csv" class="form-submit-btn">Export filtered (CSV)</button>
    </div>
    <script type="application/json" id="pipeline-reports-json"><%= raw pipeline_reports_grid_rows(@report_data).to_json %></script>
    <div id="pipelineReportsGrid" class="ag-theme-alpine" style="height: 560px; width: 100%;"></div>
    <% else %>
    <p style="text-align: center; padding: 40px; color: #6c757d; font-size: 16px;">No data available for the selected period.</p>
    <% end %>
  </div>
</div>
