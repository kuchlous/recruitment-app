<div class="dashboard-container">
  <div class="dashboard-header">
    <h2>Dashboard</h2>
  </div>
  
  <div class="stats-container">
    <div class="stat-card" data-status="New" data-action="dashboard_category">
      <div class="stat-number"><%= @new.size %></div>
      <div class="stat-label">New</div>
    </div>
    
    <div class="stat-card" data-status="Forwarded" data-action="dashboard_category">
      <div class="stat-number"><%= @forwards.size %></div>
      <div class="stat-label">Forwards</div>
    </div>
    
    <div class="stat-card" data-status="Shortlisted" data-action="dashboard_category">
      <div class="stat-number"><%= @shortlists.size %></div>
      <div class="stat-label">Shortlisted</div>
    </div>
    
    <div class="stat-card" data-status="Scheduled" data-action="dashboard_category">
      <div class="stat-number"><%= @scheduled.size %></div>
      <div class="stat-label">Scheduled</div>
    </div>
    
    <div class="stat-card" data-status="Rejected" data-action="dashboard_category">
      <div class="stat-number"><%= @rejected.size %></div>
      <div class="stat-label">Rejected</div>
    </div>
    
    <div class="stat-card" data-status="Hold" data-action="dashboard_category">
      <div class="stat-number"><%= @holds.size %></div>
      <div class="stat-label">Holds</div>
    </div>
    
    <div class="stat-card" data-status="Eng Select" data-action="dashboard_category">
      <div class="stat-number"><%= @eng_selects.size %></div>
      <div class="stat-label">Eng Select</div>
    </div>
    
    <div class="stat-card" data-status="HAC" data-action="dashboard_category">
      <div class="stat-number"><%= @hacs.size %></div>
      <div class="stat-label">HAC</div>
    </div>
    
    <div class="stat-card" data-status="Yto" data-action="dashboard_category">
      <div class="stat-number"><%= @ytos.size %></div>
      <div class="stat-label">YTO</div>
    </div>
    
    <div class="stat-card" data-status="Offered" data-action="dashboard_category">
      <div class="stat-number"><%= @offered.size %></div>
      <div class="stat-label">Offered</div>
    </div>
    
    <div class="stat-card" data-status="Joining" data-action="dashboard_category">
      <div class="stat-number"><%= @joining.size %></div>
      <div class="stat-label">Joining</div>
    </div>
  </div>
  
  <!-- Content area for displaying partials -->
  <div id="dashboard-content" class="dashboard-content" style="display: none;">
    <div class="content-header">
      <h3 id="content-title"></h3>
      <button id="close-content" class="close-btn">&times;</button>
    </div>
    <div id="content-body" class="content-body">
      <!-- Partial content will be loaded here -->
    </div>
  </div>
</div>

<script>
jQuery(document).ready(function($) {
  // Initialize AJAX stat loading for dashboard
  initializeAjaxStatLoading({
    selector: '.stat-card[data-action="dashboard_category"]',
    url: function(status) {
      return prepend_with_image_path + '/home/dashboard_category';
    },
    contentContainer: '#content-body',
    titleContainer: '#content-title'
  });
  
  // Close button functionality
  jQuery('#close-content').on('click', function() {
    jQuery('#dashboard-content').hide();
  });
  
  // Close on escape key
  jQuery(document).on('keydown', function(e) {
    if (e.key === 'Escape' && jQuery('#dashboard-content').is(':visible')) {
      jQuery('#dashboard-content').hide();
    }
  });
});
</script>
